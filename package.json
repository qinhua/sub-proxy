{
  "name": "sub-proxy",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "SubProxy",
  "author": "qinhua",
  "license": "MIT",
  "homepage": "https://github.com/qinhua/sub-proxy",
  "repository": {
    "type": "git",
