{
  "name": "sub-proxy",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "SubProxy",
  "author": "qinhua",
  "license": "MIT",
  "homepage": "https://github.com/qinhua/sub-proxy",
  "repository": {
    "type": "git",
    "url": "https://github.com/qinhua/sub-proxy.git"
  },
  "keywords": [
    "clash",
    "subproxy",
    "openclash",
    "shadowrocket",
    "clashverge"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter server run dev\" \"pnpm --filter web run dev\"",
    "build": "pnpm build:types && pnpm --filter server run build && pnpm --filter web run build",
    "build:types": "pnpm --filter @sub-proxy/types run build",
    "docker:build": "docker build -t sub-proxy:latest .",
    "docker:build:tag": "docker build -t sub-proxy:$(date +%Y%m%d-%H%M%S) .",
    "docker:save": "docker save -o sub-proxy.tar sub-proxy:latest",
    "docker:load": "docker load -i sub-proxy.tar",
    "docker:tag": "docker tag sub-proxy:latest",
    "docker:publish": "./push-to-dockerhub.sh marekqin",
    "format": "prettier -w \"**/*.{ts,tsx,js,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa__router": "^12.0.4",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.0.0",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "copy-to-clipboard": "^3.3.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  }
}