  "scripts": {
    "build": "NODE_ENV=development && pnpm --filter server run build && pnpm --filter web run build",
    "dev": "NODE_ENV=development && concurrently \"pnpm --filter server run dev\" \"pnpm --filter web run dev\"",
    "format": "prettier -w \"**/*.{ts,tsx,js,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa__router": "^12.0.4",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.0.0",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "copy-to-clipboard": "^3.3.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  }
}