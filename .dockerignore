# 排除用户数据文件
server/data/db.json
server/upload/avatar/*.jpg
server/upload/avatar/*.jpeg
server/upload/avatar/*.png
!server/upload/avatar/default_avatar.png

# 排除日志文件
logs/
*.log

# 排除开发环境文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 排除构建产物
dist/
build/

# 排除依赖
node_modules/
*/node_modules/

# 排除 Git 文件
.git/
.gitignore

# 排除 IDE 文件
.vscode/
.idea/
*.swp
*.swo

# 排除临时文件
*.tmp
*.temp