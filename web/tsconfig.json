{
  "compilerOptions": {
    "rootDir": "src",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@sub-proxy/types": ["../shared/types/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
