{
  "name": "server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon -e ts,js,json --watch src --exec \"node --import tsx src/index.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node --import tsx src/index.ts",
    "start:prod": "node --experimental-specifier-resolution=node dist/index.js"
  },
  "dependencies": {
    "@koa/router": "^12.0.2",
    "@sub-proxy/types": "workspace:*",
    "@types/multer": "^2.0.0",
    "dayjs": "^1.11.13",
    "koa": "^3.0.3",
    "koa-bodyparser": "^4.4.1",
    "koa-cors": "^0.0.16",
    "koa-send": "^5.0.1",
    "koa-static": "^5.0.0",
    "lowdb": "^7.0.1",
    "multer": "^2.0.2",
    "uuid": "^9.0.1",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/koa": "^3.0.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-cors": "^0.0.6",
    "@types/koa-send": "^4.1.6",
    "@types/koa-static": "^4.0.4",
    "@types/node": "^22.7.8",
    "@types/uuid": "^11.0.0",
    "nodemon": "^3.1.7",
    "readdirp": "^4.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.6.3"
  }
